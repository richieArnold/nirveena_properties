) {
(() => {
  // ---- Config ----
  const NAMES = [
  "Mr. Aarav Verma","Mr. Vihaan Sharma","Mr. Advait Nair","Mr. Arjun Reddy","Mr. Ishaan Gupta",
  "Mr. Karthik Iyer","Mr. Rohan Mehta","Mr. Siddharth Rao","Mr. Yuvraj Singh","Mr. Manish Kumar",
  "Mr. Vikram Desai","Mr. Amit Bansal","Mr. Rahul Bhatt","Mr. Neeraj Sethi","Mr. Ankit Malhotra",
  "Ms. Aanya Kapoor","Ms. Diya Nair","Ms. Ishita Rao","Ms. Kavya Menon","Ms. Meera Kulkarni",
  "Ms. Nisha Gupta","Ms. Riya Singh","Ms. Sana Khan","Ms. Shruti Sharma","Ms. Tanvi Patel",
  "Ms. Ananya Iyer","Ms. Priya Reddy","Ms. Simran Kaur","Ms. Pooja Verma","Ms. Neha Agarwal",
  "Mr. Harsh Vardhan","Mr. Saurabh Jain","Mr. Abhishek Tiwari","Mr. Nitin Chauhan","Mr. Deepak Yadav",
  "Mr. Amitesh Prasad","Mr. Raghav Bhatia","Mr. Parth Khandelwal","Mr. Jayant Joshi","Mr. Akash Sinha",
  "Mr. Chirag Goel","Mr. Rajat Kapoor","Mr. Pranav Mittal","Mr. Siddhant Ghosh","Mr. Akhil Menon",
  "Ms. Ayesha Khan","Ms. Bhavna Choudhary","Ms. Charu Joshi","Ms. Divya Nambiar","Ms. Ekta Sinha",
  "Ms. Garima Tandon","Ms. Hina Batra","Ms. Ira Malhotra","Ms. Juhi Saxena","Ms. Kiran Thakur",
  "Ms. Lavanya Nair","Ms. Megha Gupta","Ms. Namrata Das","Ms. Ojasvi Reddy","Ms. Parul Kapoor",
  "Ms. Reema Chopra","Ms. Shalini Singh","Ms. Trisha Banerjee","Ms. Urmi Patel","Ms. Vidhi Desai",
  "Ms. Zoya Ahmed","Ms. Anushka Sharma","Ms. Kritika Verma","Ms. Pallavi Mehta","Ms. Ritika Malhotra",
  "Ms. Sneha Iyer","Ms. Tanya Rao","Ms. Vandana Menon","Ms. Yamini Reddy","Ms. Sanya Kapoor",
  "Mr. Devansh Gupta","Mr. Ishan Malhotra","Mr. Mohit Bansal","Mr. Naveen Reddy","Mr. Prateek Sharma",
  "Mr. Rajat Malhotra","Mr. Sahil Khanna","Mr. Tarun Goyal","Mr. Uday Singh","Mr. Varun Kapoor",
  "Mr. Anirudh Rao","Mr. Bhavesh Patel","Mr. Chandan Nair","Mr. Darshan Mehta","Mr. Eshan Iyer",
  "Mr. Faisal Khan","Mr. Gaurav Sharma","Mr. Hemant Kumar","Mr. Inderjeet Singh","Mr. Jai Prakash",
  "Mr. Kunal Sethi","Mr. Lokesh Sharma","Mr. Mayank Agarwal","Mr. Nikhil Bhatia","Mr. Om Prakash"
];
  const ACTIONS = [
    "viewed the floor plan",
    "downloaded the brochure",
    "booked a site visit",
    "unlocked the price",
    "downloaded floorplans",
    "scheduled a callback"
  ];
  const WHEN = ["just now","moments ago","a few seconds ago"];

  const CORNER = "top-left";       // keep as requested
  const SCROLL_TRIGGER_PX = 160;   // first-fold threshold
  const DISPLAY_MS = 3000;         // stays visible ~3s
  const INTERVAL_MIN_MS = 10000;   // at least 10s between nudges
  const INTERVAL_MAX_MS = 14000;   // slight randomness
  const MAX_STACK = 1;             // calm UI
  const MAX_PER_SESSION = 8;       // 7–8 per session

  // ---- Styles ----
  const css = `
  .spn-container{position:fixed;z-index:217;pointer-events:none;padding:8px}
  .spn-container.top-left{top:10px;left:10px}
  .spn-container.top-right{top:10px;right:10px}
  .spn-nudge{
    pointer-events:auto; display:flex; align-items:center; gap:8px;
    background:rgba(17,17,17,.42); color:rgba(255,255,255,.92); border-radius:12px;
    box-shadow:0 6px 20px rgba(0,0,0,.12); padding:7px 9px;
    backdrop-filter:saturate(140%) blur(4px); -webkit-backdrop-filter:saturate(140%) blur(4px);
    max-width:min(86vw,300px); font:500 12.5px/1.25 system-ui,-apple-system,Segoe UI,Roboto;
    transform:translateY(-10px); opacity:0; transition:transform .24s ease,opacity .24s ease;
  }
  .spn-nudge.show{opacity:1; transform:translateY(0)}
  .spn-avatar{flex:0 0 20px; height:20px; width:20px; border-radius:999px;
    display:grid; place-items:center; background:rgba(255,255,255,.10)}
  .spn-avatar svg{height:12px;width:12px;opacity:.9}
  .spn-copy b{font-weight:700}
  .spn-close{margin-left:6px; opacity:.6; cursor:pointer; border:0; background:transparent;
    color:#fff; font-size:16px; line-height:1; padding:0 2px}
  @media (max-width:480px){ .spn-nudge{font-size:12px; max-width:84vw;} }`;
  if (!document.getElementById("spn-style")) {
    const s = document.createElement("style"); s.id = "spn-style"; s.textContent = css; document.head.appendChild(s);
  }

  // ---- Container ----
  let container = document.getElementById("spn-container");
  if (!container) {
    container = document.createElement("div");
    container.id = "spn-container";
    container.className = `spn-container ${CORNER}`;
    document.body.appendChild(container);
  }

  // ---- Helpers ----
  const rng = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;
  const pick = arr => arr[rng(0, arr.length - 1)];

  // ---- State ----
  let running = false;
  let started = false;
  let sessionCount = 0;
  let nextTimer = null;

  function scheduleNext(delayMs){
    clearTimeout(nextTimer);
    nextTimer = setTimeout(() => {
      if (!running) return;
      if (sessionCount >= MAX_PER_SESSION) { stopCycle(); return; }
      createNudge();
      sessionCount++;
      scheduleNext(rng(INTERVAL_MIN_MS, INTERVAL_MAX_MS));
    }, delayMs);
  }

  function startCycle(){
    if (running || sessionCount >= MAX_PER_SESSION) return;
    running = true;
    scheduleNext(rng(INTERVAL_MIN_MS, INTERVAL_MAX_MS));
  }

  function stopCycle(){
    running = false;
    clearTimeout(nextTimer);
    nextTimer = null;
    clearAll();
  }

  function clearAll(){
    [...container.children].forEach((el)=>hideNudge(el, true));
  }

  function createNudge(){
    if (document.hidden) return;
    if (container.children.length >= MAX_STACK) return;

    const name = pick(NAMES);
    const action = pick(ACTIONS);
    const when = pick(WHEN);

    const n = document.createElement("div");
    n.className = "spn-nudge";
    n.setAttribute("role","status");
    n.setAttribute("aria-live","polite");
    n.style.marginTop = "8px";

    const avatar = document.createElement("div");
    avatar.className = "spn-avatar";
    avatar.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 12c2.9 0 5.25-2.69 5.25-6S14.9 0 12 0 6.75 2.24 6.75 6 9.1 12 12 12Zm0 1.8c-4.6 0-8.5 2.31-8.5 5.3V21H20.5v-1.9c0-2.99-3.9-5.3-8.5-5.3Z"/></svg>`;

    const copy = document.createElement("div");
    copy.className = "spn-copy";
    copy.innerHTML = `<b>${name}</b> ${action} ${when}.`;

    const close = document.createElement("button");
    close.className = "spn-close"; close.setAttribute("aria-label","Hide notification"); close.textContent = "×";
    close.addEventListener("click",(e)=>{ e.stopPropagation(); hideNudge(n); });

    n.appendChild(avatar); n.appendChild(copy); n.appendChild(close);

    container.appendChild(n);
    requestAnimationFrame(()=> n.classList.add("show"));

    let hideId = setTimeout(()=>hideNudge(n), DISPLAY_MS);
    n.addEventListener("mouseenter", ()=>clearTimeout(hideId));
    n.addEventListener("mouseleave", ()=> hideId = setTimeout(()=>hideNudge(n), DISPLAY_MS));
    setTimeout(()=>{ if (document.body.contains(n)) hideNudge(n); }, DISPLAY_MS + 2000);
  }

  function hideNudge(el, immediate=false){
    if (!el) return;
    if (immediate) { el.remove(); return; }
    el.classList.remove("show");
    setTimeout(()=> el.remove(), 220);
  }

  // ---- Scroll gating ----
  function handleScrollGate(){
    const y = window.scrollY || document.documentElement.scrollTop || 0;
    if (y >= SCROLL_TRIGGER_PX) {
      if (!started) started = true;
      startCycle();
    } else {
      stopCycle();
    }
  }

  window.addEventListener('scroll', ()=>requestAnimationFrame(handleScrollGate), {passive:true});
  window.addEventListener('load', handleScrollGate);
})();
}



 
 
