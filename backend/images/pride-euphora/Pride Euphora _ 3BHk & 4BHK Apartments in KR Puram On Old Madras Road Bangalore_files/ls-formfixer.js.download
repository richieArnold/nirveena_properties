(function () {
  "use strict";

  // =========================
  // Safe helpers
  // =========================
  function q(sel, root) { try { return (root || document).querySelector(sel); } catch (e) { return null; } }
  function hasEl(el) { return !!(el && el.nodeType === 1); }
  function attrLower(el, name) {
    try { return String(el.getAttribute(name) || "").toLowerCase().trim(); } catch (e) { return ""; }
  }
  function setAttrSafe(el, name, val) {
    try { el.setAttribute(name, val); } catch (e) {}
    try { el[name] = val; } catch (e) {}
  }
  function onlyDigits(s) { return String(s || "").replace(/\D+/g, ""); }

  // =========================
  // Find fields (id-first, then safe fallback)
  // =========================
  function findPhoneInput() {
    var el = document.getElementById("phonenumb");
    if (hasEl(el)) return el;

    // common phone-like
    el = q('input[type="tel"][id*="phone" i],input[type="tel"][name*="phone" i],input[type="tel"][id*="mobile" i],input[type="tel"][name*="mobile" i]');
    if (hasEl(el)) return el;

    // SAFE fallback: only pick a tel input if it is inside an intl-tel wrapper
    var tel = q('input[type="tel"]');
    if (hasEl(tel)) {
      try {
        var wrap = (typeof tel.closest === "function") ? tel.closest(".intl-tel-input, .iti") : null;
        if (wrap) return tel;
      } catch (e) {}
    }
    return null;
  }

  function findNameInput() {
    var el = document.getElementById("userName");
    if (hasEl(el)) return el;
    el = q('input[type="text"][autocomplete="name"],input[type="text"][name*="name" i],input[type="text"][id*="name" i]');
    return hasEl(el) ? el : null;
  }

  function findEmailInput() {
    var el = document.getElementById("userEmail");
    if (hasEl(el)) return el;
    el = q('input[type="email"],input[type="text"][name*="email" i],input[type="text"][id*="email" i]');
    return hasEl(el) ? el : null;
  }

  // =========================
  // Autocomplete (only if missing/empty/off)
  // =========================
  function ensureAutocomplete(el, val) {
    if (!hasEl(el)) return;
    var cur = attrLower(el, "autocomplete");
    if (!cur || cur === "off") setAttrSafe(el, "autocomplete", val);
  }

  function ensureFormAutocompleteOn(input) {
    try {
      if (input && input.form) {
        var fcur = attrLower(input.form, "autocomplete");
        if (fcur === "off") input.form.setAttribute("autocomplete", "on");
      }
    } catch (e) {}
  }

  // =========================
  // Dial detection (NO guesswork)
  // Reads only from THIS input's wrapper flag title "...: +91"
  // =========================
  function findSelectedFlagForInput(input) {
    try {
      var wrap = (typeof input.closest === "function")
        ? input.closest(".intl-tel-input, .iti")
        : null;
      if (!wrap) return null;
      return wrap.querySelector(".selected-flag, .iti__selected-flag");
    } catch (e) {
      return null;
    }
  }

  function dialFromFlagTitle(flagEl) {
    try {
      if (!flagEl) return "";
      var title = (flagEl.getAttribute && flagEl.getAttribute("title")) || "";
      if (!title) return "";
      var m = title.match(/:\s*\+?\s*([\d\s]+)\s*$/);
      if (!m) return "";
      var dial = onlyDigits(String(m[1] || "").replace(/\s+/g, ""));
      return dial || "";
    } catch (e) {
      return "";
    }
  }

  // =========================
  // ISD helper injection (outside iti wrapper)
  // - not display:none
  // - stable marker, no duplicates
  // =========================
  function findExistingHelper(forId) {
    try {
      var all = document.querySelectorAll('input[data-sf-isd-helper="1"]');
      for (var i = 0; i < all.length; i++) {
        if (all[i] && all[i].getAttribute("data-for") === forId) return all[i];
      }
    } catch (e) {}
    return null;
  }

  function ensureIsdHelper(input) {
    if (!hasEl(input)) return null;

    var inputId = input.id || "phonenumb";
    var existing = findExistingHelper(inputId);
    if (hasEl(existing)) return existing;

    var helper = document.createElement("input");
    helper.type = "tel";
    helper.inputMode = "tel";
    helper.tabIndex = -1;
    helper.setAttribute("aria-hidden", "true");

    helper.name = "sf_isd_" + Math.random().toString(36).slice(2, 9);
    helper.id   = "sf_isd_" + Math.random().toString(36).slice(2, 9);
    helper.setAttribute("autocomplete", "tel-country-code");

    helper.setAttribute("data-sf-isd-helper", "1");
    helper.setAttribute("data-for", inputId);

    // off-screen but "present"
    helper.style.position = "absolute";
    helper.style.left = "-9999px";
    helper.style.top = "0";
    helper.style.width = "1px";
    helper.style.height = "1px";
    helper.style.opacity = "0.01";   // NOT 0
    helper.style.pointerEvents = "none";

    // insert OUTSIDE wrapper so iti never removes it
    try {
      var wrap = (typeof input.closest === "function") ? input.closest(".intl-tel-input, .iti") : null;
      if (wrap && wrap.parentNode) wrap.parentNode.insertBefore(helper, wrap.nextSibling);
      else if (input.parentNode) input.parentNode.insertBefore(helper, input.nextSibling);
      else document.body.appendChild(helper);
    } catch (e) {}

    return helper;
  }

  function syncHelperWithFlag(input, helper) {
    if (!hasEl(input) || !hasEl(helper)) return;
    var flag = findSelectedFlagForInput(input);
    var dial = dialFromFlagTitle(flag);
    if (!dial) return; // no dial => do nothing
    helper.value = "+" + dial;
  }

  // =========================
  // Submit-only cleanup (NO guesswork)
  // =========================
  function stripDialIfExactMatch_submitOnly(input) {
    if (!hasEl(input)) return;

    var raw = String(input.value || "").trim();
    if (!raw || raw.charAt(0) !== "+") return;

    var flag = findSelectedFlagForInput(input);
    var dial = dialFromFlagTitle(flag);
    if (!dial) return;

    var digits = onlyDigits(raw);
    if (digits.indexOf(dial) !== 0) return;
    if (digits.length <= dial.length) return;

    var national = digits.slice(dial.length).replace(/^0+/, "");
    if (!national) return;

    input.value = national;
  }

  // =========================
  // Init + wiring
  // =========================
  function init() {
    var nameEl  = findNameInput();
    var emailEl = findEmailInput();
    var phoneEl = findPhoneInput();

    if (!hasEl(nameEl) && !hasEl(emailEl) && !hasEl(phoneEl)) return;

    ensureAutocomplete(nameEl, "name");
    ensureAutocomplete(emailEl, "email");
    ensureAutocomplete(phoneEl, "tel");
    if (hasEl(phoneEl)) ensureFormAutocompleteOn(phoneEl);

    if (!hasEl(phoneEl)) return;

    // HARD GUARD: only run helper/strip logic if it's actually an intl-tel input
    var wrap = null;
    try { wrap = (typeof phoneEl.closest === "function") ? phoneEl.closest(".intl-tel-input, .iti") : null; } catch (e) {}
    if (!wrap) return;

    var helper = ensureIsdHelper(phoneEl);
    syncHelperWithFlag(phoneEl, helper);

    try {
      phoneEl.addEventListener("countrychange", function () {
        syncHelperWithFlag(phoneEl, helper);
      }, true);
    } catch (e) {}

    function cleanup() {
      syncHelperWithFlag(phoneEl, helper);
      stripDialIfExactMatch_submitOnly(phoneEl);
    }

    try {
      var form = phoneEl.form || (phoneEl.closest ? phoneEl.closest("form") : null);
      if (form) form.addEventListener("submit", cleanup, true);

      if (form) {
        form.addEventListener("click", function (ev) {
          var t = ev && ev.target;
          if (!t) return;
          var tag = (t.tagName || "").toUpperCase();
          var type = String(t.type || "").toLowerCase();
          if ((tag === "BUTTON" && type === "submit") || (tag === "INPUT" && type === "submit")) cleanup();
        }, true);
      }
    } catch (e) {}

    var btn = document.getElementById("myBtn");
    if (hasEl(btn)) {
      try { btn.addEventListener("click", cleanup, true); } catch (e) {}
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
})();











